{
  "name": "commercialwebsite-web",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "git@github.com:BenCaro8/CommercialWebsite.git",
  "author": "<benjamincaro8@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"webpack serve --hot --mode development\" \"yarn typed-scss-modules src --watch --suppress\"",
    "ts": "tsc --noemit",
    "lint": "eslint \"**/*.{ts,tsx}\" && yarn ts",
    "intl": "formatjs extract 'src/**/*.{ts,tsx}' --ignore 'src/**/*.{scss,scss.d.ts}' --out-file locales/en.json && formatjs compile locales/en.json --out-file locales/en.json",
    "build": "webpack --mode production --node-env production",
    "codegen": "graphql-codegen",
    "dockerbuild": "docker image build --no-cache -t commercialwebsite:latest .",
    "dockerstart": "docker run -dp 80:80 --name commercialwebsitecontainer commercialwebsite:latest",
    "storybook": "concurrently \"storybook dev -p 6006\" \"yarn typed-scss-modules src --watch\"",
    "build-storybook": "storybook build"
  },
  "imports": {
    "#gql": "./src/__generated__/gql.ts"
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@reduxjs/toolkit": "^2.8.2",
    "classnames": "^2.5.1",
    "graphql": "^16.9.0",
    "prettier": "^3.6.2",
    "react": "^19.1.0",
    "react-color": "^2.19.3",
    "react-dom": "^19.1.0",
    "react-intl": "^7.1.5",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.6.3",
    "three": "^0.167.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@babel/register": "^7.23.7",
    "@chromatic-com/storybook": "3.2.2",
    "@formatjs/cli": "^6.3.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
    "@storybook/addon-essentials": "8.4.2",
    "@storybook/addon-interactions": "8.4.2",
    "@storybook/addon-onboarding": "8.4.2",
    "@storybook/addon-styling-webpack": "1.0.1",
    "@storybook/blocks": "8.4.2",
    "@storybook/react": "8.4.2",
    "@storybook/react-webpack5": "8.4.2",
    "@storybook/test": "8.4.2",
    "@types/react": "^19.1.8",
    "@types/react-color": "^3.0.12",
