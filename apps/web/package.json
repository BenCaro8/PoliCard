    "@types/webpack-dev-server": "^4.7.2",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "babel-loader": "^9.1.3",
    "babel-plugin-formatjs": "^10.5.22",
    "compression-webpack-plugin": "^11.1.0",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
