{
  "name": "commercialwebsite-graphql",
  "version": "1.0.0",
  "main": "server.ts",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "tsx ./src/server.ts",
    "dev": "tsx watch ./src/server.ts",
    "ts": "tsc --noemit",
    "build": "webpack --mode production --node-env production",
    "run-build": "node dist/server.js",
    "lint": "eslint \"**/*.{ts,tsx}\" && yarn ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "generate-schema": "tsx generateSchema.ts"
  },
  "imports": {
    "#gql-types": "./src/types/__generated__/types.ts",
    "#gql-context": "./src/types/context.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.2",
    "@aws-sdk/client-cognito-identity-provider": "^3.723.0",
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/lib-storage": "^3.726.1",
    "@google/generative-ai": "^0.21.0",
    "@graphql-tools/merge": "^9.0.10",
    "@graphql-tools/schema": "^10.0.9",
    "@graphql-tools/utils": "^10.6.0",
    "aws-jwt-verify": "^5.0.0",
    "axios": "^1.7.9",
    "body-parser": "^1.20.3",
    "camelcase-keys": "^9.1.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "elevenlabs": "^1.50.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.21.0",
    "eslint-plugin-promise": "^7.2.1",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "graphql": "^16.9.0",
    "graphql-upload": "^17.0.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "openai": "^6.32.0",
    "pg": "^8.16.3",
    "pg-promise": "^11.15.0",
    "pg-query-stream": "^4.10.3",
    "prettier": "^3.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.3",
    "@graphql-codegen/near-operation-file-preset": "^3.0.0",
    "@graphql-codegen/typescript": "4.1.1",
    "@graphql-codegen/typescript-resolvers": "4.4.0",
    "@swc/core": "^1.10.7",
    "@swc/register": "^0.1.10",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.0",
    "@types/graphql-upload": "^17.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-prettier": "^5.2.1",
    "ts-loader": "^9.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  }
}
